          "name": "Create entry — happy path (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(res.id).to.be.a('number'));",
                  "pm.test('Status is pending', () => pm.expect(res.status).to.eql('pending'));",
                  "if (res.id) pm.collectionVariables.set('lastCreatedEntryId', String(res.id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startTime\": \"2026-06-14T09:00:00Z\",\n  \"endTime\": \"2026-06-14T17:30:00Z\",\n  \"project\": \"HRIS-Migration\",\n  \"notes\": \"Schema work\"\n}",
