    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "employeeId1", "value": "1", "type": "string" },
    { "key": "employeeId2", "value": "2", "type": "string" },
    { "key": "managerId", "value": "1", "type": "string" },
